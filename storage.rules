rules_version = '2';

// Chytayko — Storage security (TECHNICAL_PASSPORT §12, §20)
// Story assets: public read. User files: owner only. No client writes in MVP.

service firebase.storage {
  match /b/{bucket}/o {
    match /stories/{storySlug}/{fileName} {
      allow read: if true;
      allow write: if false;
    }

    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
