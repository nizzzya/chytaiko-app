# Chytayko — Firebase (Expo public variables)
# Copy to .env or .env.development and fill from Firebase Console → Project settings → Your apps → Web app config.
# Never commit .env files with real values.

# Required — Web API key
EXPO_PUBLIC_FIREBASE_API_KEY=

# Required — e.g. your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=

# Required — Firebase project ID
EXPO_PUBLIC_FIREBASE_PROJECT_ID=

# Required — e.g. your-project.appspot.com
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=

# Required — Cloud Messaging sender ID (numeric)
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=

# Required — Firebase app ID
EXPO_PUBLIC_FIREBASE_APP_ID=
